PORT=3001
JWT_SECRET=polar_odeia_todos_vdd
JWT_EXPIRES_IN=7d
GEMINI_API_KEY=AIzaSyBXBpFWF5l2AGGku2LepFjy7jn1T6SaKkU

# URL do seu frontend no Vercel (sem barra no final)
ALLOWED_ORIGIN=https://folium-clue.vercel.app

# Render preenche DATABASE_URL automaticamente
# quando você linka o PostgreSQL ao serviço
DATABASE_URL=postgresql://folium_db_user:rbpkJxG6oAn8LuIB8e5p9WQY9tMwYfc0@dpg-d741eglm5p6s73f0da0g-a/folium_db

# ── Login com Google (obrigatório para "Continuar com Google") ──
# Crie em https://console.cloud.google.com/apis/credentials
# Tipo: OAuth Client ID → Web application
# Adicione as origens autorizadas (ex.: https://folium-clue.vercel.app,
# http://localhost:3000) para o Google Identity Services.
GOOGLE_OAUTH_CLIENT_ID=

# ── SMTP para envio do código de verificação ──
# Gere uma senha de app do Gmail em https://myaccount.google.com/apppasswords
# (requer verificação em 2 etapas habilitada na conta).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=suporte.folium@gmail.com
SMTP_PASSWORD=
EMAIL_FROM=suporte.folium@gmail.com
EMAIL_FROM_NAME=Folium

# ── Tunings do código de verificação (opcionais) ──
VERIFICATION_CODE_TTL_MIN=10
VERIFICATION_MAX_ATTEMPTS=5
VERIFICATION_MAX_RESENDS=3
