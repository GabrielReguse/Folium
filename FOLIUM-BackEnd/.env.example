# ══════════════════════════════════════
#  FOLIUM — Variáveis de ambiente
#  No Render: adicione pelo painel
#  Dashboard → seu serviço → Environment
# ══════════════════════════════════════

PORT=3001
JWT_SECRET=troque_por_algo_longo_e_aleatorio_aqui
JWT_EXPIRES_IN=7d

# URL do seu frontend no Vercel (sem barra no final)
ALLOWED_ORIGIN=https://seu-projeto.vercel.app

# Render preenche DATABASE_URL automaticamente
# quando você linka o PostgreSQL ao serviço
DATABASE_URL=postgresql://usuario:senha@host:5432/folium
